page {
  background: #f4f6f9;
  color: #333333;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(13, 27, 76, 0.05);
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #0d1b4c, #1a3680);
  color: #ffffff;
  border-radius: 48rpx;
  font-weight: 600;
  font-size: 32rpx;
  box-shadow: 0 8rpx 16rpx rgba(13, 27, 76, 0.2);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #9ca3af;
  font-size: 28rpx;
}
