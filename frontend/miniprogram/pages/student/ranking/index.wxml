<view class="page">
  <view class="header-card">
    <text class="header-title">🏆 本周积分排行榜</text>
  </view>
  
  <view class="card item rank-{{index + 1}}" wx:for="{{list}}" wx:key="user_id">
    <view class="rank-badge {{index < 3 ? 'top-' + (index + 1) : ''}}">
      <text wx:if="{{index > 2}}">{{index + 1}}</text>
      <text wx:if="{{index === 0}}">👑</text>
      <text wx:if="{{index === 1}}">🥈</text>
      <text wx:if="{{index === 2}}">🥉</text>
    </view>
    <view class="user-info">
      <text class="name">{{item.nickname}}</text>
      <text class="total-score" wx:if="{{item.total_score}}">总分：{{item.total_score}}</text>
    </view>
    <view class="score-box">
      <text class="score">{{item.week_score}}</text>
      <text class="score-unit">分</text>
    </view>
  </view>
  
  <view class="empty-state" wx:if="{{list.length === 0}}">
    <text>暂无排行数据</text>
  </view>
</view>
