<view class="page">
  <view class="card">
    <view class="section-title">上传答题图片</view>
    <view class="grid">
      <view class="img-box" wx:for="{{images}}" wx:key="*this">
        <image class="img" src="{{item}}" mode="aspectFill" bindtap="preview" data-index="{{index}}" />
        <view class="delete-btn" data-index="{{index}}" bindtap="removeImage">✕</view>
      </view>
      <view class="upload-btn" bindtap="addImages" wx:if="{{images.length < 9}}">
        <text class="plus-icon">+</text>
        <text class="upload-text">添加图片</text>
      </view>
    </view>
  </view>
  <button class="btn-primary" bindtap="submitAnswer">提交答案</button>
</view>
