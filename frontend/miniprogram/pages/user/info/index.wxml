<view class="page">
  <view class="header-card">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo.avatar_url || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <text class="name">{{userInfo.real_name || userInfo.nickname}}</text>
      <text class="role-tag {{userInfo.role === 'teacher' ? 'teacher' : 'student'}}">{{userInfo.role === 'teacher' ? '教师' : '学生'}}</text>
    </view>
  </view>

  <view class="info-list">
    <view class="info-item">
      <text class="label">手机号</text>
      <text class="value">{{userInfo.phone}}</text>
    </view>
    <view class="info-item">
      <text class="label">真实姓名</text>
      <text class="value">{{userInfo.real_name || '未填写'}}</text>
    </view>
    <view class="info-item">
      <text class="label">学院</text>
      <text class="value">{{userInfo.college || '未填写'}}</text>
    </view>
    
    <block wx:if="{{userInfo.role === 'student'}}">
      <view class="info-item">
        <text class="label">专业</text>
        <text class="value">{{userInfo.major || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="label">学校</text>
        <text class="value">{{userInfo.school || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="label">年级</text>
        <text class="value">{{userInfo.grade || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="label">班级</text>
        <text class="value">{{userInfo.class_name || '未填写'}}</text>
      </view>
    </block>
  </view>

  <button class="btn-edit" bindtap="goEditProfile">修改资料</button>
  <button class="btn-logout" bindtap="handleLogout">退出登录</button>
</view>