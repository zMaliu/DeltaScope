.page {
  min-height: 100vh;
  background-color: #f5f6fa;
  padding-bottom: 60rpx;
}

.header-card {
  background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  align-items: center;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(59, 130, 246, 0.2);
}

.avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background-color: #fff;
  padding: 6rpx;
  margin-right: 30rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #e2e8f0;
}

.user-info {
  flex: 1;
}

.name {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}

.role-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.role-tag.student {
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.role-tag.teacher {
  background-color: #f59e0b;
  color: #fff;
}

.info-list {
  background: #fff;
  border-radius: 20rpx;
  margin: -40rpx 30rpx 40rpx;
  padding: 10rpx 30rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 30rpx;
  color: #64748b;
}

.value {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}

.btn-edit {
  margin: 40rpx 30rpx 20rpx;
  background: #1e3a8a;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-logout {
  margin: 0 30rpx;
  background: #fff;
  color: #ef4444;
  border-radius: 48rpx;
  font-size: 32rpx;
  border: 2rpx solid #fecdd3;
}