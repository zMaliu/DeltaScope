<view class="page">
  <view class="header">
    <text class="greeting">老师工作台</text>
    <view class="header-actions">
      <text class="profile-btn" bindtap="goProfile">👤 个人中心</text>
    </view>
  </view>

  <view class="actions-bar">
    <button class="btn-publish" bindtap="goPublish">发布本周新题</button>
  </view>
  
  <view class="card row" wx:for="{{list}}" wx:key="id" bindtap="openDetail" data-id="{{item.id}}">
    <view class="row-header">
      <text class="student-name">学生ID：{{item.student_id}}</text>
      <text class="tag {{item.status === 'submitted' ? 'tag-submitted' : 'tag-graded'}}">
        {{item.status === 'submitted' ? '待批改' : '已批改'}}
      </text>
    </view>
    <view class="row-body">
      <text class="submit-time">提交时间：{{item.submit_time}}</text>
      <text class="arrow">></text>
    </view>
  </view>
  <view class="empty-state" wx:if="{{list.length === 0}}">
    <text>暂无学生提交</text>
  </view>
</view>
