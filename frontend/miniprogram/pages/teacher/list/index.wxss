.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.greeting {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.profile-btn {
  font-size: 26rpx;
  color: #3b82f6;
  background: #eff6ff;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.page {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.actions-bar {
  margin-bottom: 30rpx;
}

.btn-publish {
  background: linear-gradient(90deg, #1e3a8a, #3b82f6);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.3);
}

.row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 30rpx;
}

.row-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.student-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-submitted {
  background: #fffbeb;
  color: #d97706;
}

.tag-graded {
  background: #f0fdf4;
  color: #16a34a;
}

.row-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.submit-time {
  font-size: 26rpx;
  color: #6b7280;
}

.arrow {
  color: #9ca3af;
  font-weight: bold;
}
