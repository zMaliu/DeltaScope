<view class="page">
  <view class="card">
    <text class="title">发布新题</text>
    
    <view class="form-group">
      <text class="label">本题满分</text>
      <input class="input" type="number" placeholder="例如：100" value="{{maxScore}}" bindinput="onScoreInput" />
    </view>
    
    <view class="form-group">
      <text class="label">截止时间</text>
      <picker mode="date" value="{{deadlineDate}}" bindchange="onDateChange">
        <view class="picker-value">{{deadlineDate || '选择日期'}}</view>
      </picker>
      <picker mode="time" value="{{deadlineTime}}" bindchange="onTimeChange">
        <view class="picker-value">{{deadlineTime || '选择时间'}}</view>
      </picker>
    </view>
    
    <view class="form-group">
      <text class="label">题目图片 (最多9张)</text>
      <view class="image-list">
        <image class="preview-img" wx:for="{{imageUrls}}" wx:key="*this" src="{{app.globalData.baseUrl + item}}" mode="aspectFill"></image>
        <view class="upload-btn" bindtap="chooseImage" wx:if="{{imageUrls.length < 9}}">
          <text class="plus">+</text>
        </view>
      </view>
    </view>
    
    <button class="btn-primary" bindtap="submitPublish" loading="{{loading}}">立即发布</button>
  </view>
</view>