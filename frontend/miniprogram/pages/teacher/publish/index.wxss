.page {
  padding: 30rpx;
  background-color: #f5f6fa;
  min-height: 100vh;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  display: block;
  text-align: center;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.input, .picker-value {
  background: #f8fafc;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e5e7eb;
  margin-bottom: 16rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.preview-img, .upload-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.upload-btn {
  background: #f8fafc;
  border: 2rpx dashed #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plus {
  font-size: 60rpx;
  color: #94a3b8;
}

.btn-primary {
  margin-top: 60rpx;
  background: linear-gradient(90deg, #1e3a8a, #3b82f6);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
}