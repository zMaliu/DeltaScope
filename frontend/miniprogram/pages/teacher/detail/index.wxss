.page {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.info-title {
  font-size: 32rpx;
  font-weight: 600;
}

.status {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-submitted { background: #fffbeb; color: #d97706; }
.status-graded { background: #f0fdf4; color: #16a34a; }

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.label {
  color: #6b7280;
  width: 140rpx;
}

.value {
  color: #1f2937;
  font-weight: 500;
}

.section-label {
  display: block;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #4b5563;
  font-weight: 500;
}

.image-list {
  white-space: nowrap;
}

.img {
  width: 240rpx;
  height: 240rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.05);
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input-field {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.textarea-field {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  width: auto;
  min-height: 180rpx;
  font-size: 28rpx;
}
