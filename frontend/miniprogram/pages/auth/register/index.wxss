.page {
  min-height: 100vh;
  padding: 40rpx 30rpx;
  background: radial-gradient(circle at top, #20327b, #0a1238 60%, #060b21);
}

.hero {
  margin-top: 80rpx;
  margin-bottom: 40rpx;
}

.brand {
  display: block;
  font-size: 58rpx;
  color: #ffffff;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
}

.auth-card {
  border-radius: 28rpx;
  box-shadow: 0 20rpx 60rpx rgba(7, 12, 37, 0.35);
  padding: 40rpx 30rpx;
  background: #ffffff;
}

.tabs {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.tab {
  padding: 16rpx 0;
  font-size: 32rpx;
  color: #64748b;
  position: relative;
}

.tab.active {
  color: #1e3a8a;
  font-weight: bold;
}

.tab.active::after {
  content: "";
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #1e3a8a;
  border-radius: 3rpx;
}

.input {
  background: #f8fafc;
  height: 88rpx;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  color: #334155;
  border: 2rpx solid #e5e7eb;
}

.auth-input {
  border-color: #cbd5e1;
}

.switch-line {
  margin-top: 30rpx;
  text-align: center;
  color: #64748b;
  font-size: 26rpx;
}

.btn-primary {
  margin-top: 40rpx;
  background: linear-gradient(90deg, #1e3a8a, #3b82f6);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.3);
}
